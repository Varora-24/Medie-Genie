# Database Configuration (Supabase PostgreSQL)
# Replace with your actual connection strings
DATABASE_URL="postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres"

# NextAuth Configuration
NEXTAUTH_SECRET="your-random-32-character-secret-key-goes-here"
AUTH_SECRET="your-random-32-character-secret-key-goes-here"

# Application URL
# MUST be set to the exact URL of the application.
# For local development: http://localhost:3000
# For production (Vercel): The actual production URL (e.g. https://your-app.vercel.app)
AUTH_URL="http://localhost:3000"

# Google OAuth Credentials
AUTH_GOOGLE_ID="your-google-client-id-here"
AUTH_GOOGLE_SECRET="your-google-client-secret-here"

# Supabase Storage Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-api-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-for-bypassing-rls-on-server"

# Gemini API (AI Symptom Chatbot)
GEMINI_API_KEY="your-gemini-api-key"

# Google Maps API (Phase 5 Find Care) - REPLACED WITH OPENSTREETMAP (NO KEY REQUIRED)

# Application-level Encryption (Phase 4 Doctor Notes)
# WARNING: If this key is lost, existing doctor notes cannot be decrypted.
# Generate via: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encoded-key-here"

# Stripe Payments (Phase 4)
# MUST use test keys during development (sk_test_ / pk_test_)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
